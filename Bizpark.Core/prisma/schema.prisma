generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum TaskStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum TaskType {
  WEBSITE_GENERATION
  SOCIAL_MEDIA_CONTENT
  BLOG_POST_WRITING
}

enum SubscriptionTier {
  FREE
  PRO
  AGENCY
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// --- ENTITIES ---

// 1. Users
model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  name             String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  // Relations
  businesses       BusinessUser[]
}

// 2. Business Profile / Workspace (The Central Entity)
model Business {
  id               String           @id @default(uuid())
  name             String           
  category         String?          
  description      String?          
  logoUrl          String?
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  // Relations
  users            BusinessUser[]
  websites         Website[]
  products         Product[]
  agentTasks       AgentTask[]
  socialPosts      SocialMediaPost[]
}

// 2.1 Many-to-Many Users <-> Businesses
model BusinessUser {
  userId     String
  businessId String
  role       UserRole @default(EDITOR)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@id([userId, businessId])
}

// 3. Products / Services (Used as context for Genkit)
model Product {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?  
  price       Float?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum TemplateType {
  SHOWCASE
  ECOMMERCE_ITEM
  ECOMMERCE_SUBSCRIPTION
}

// 4. Headless CMS & Templates
model Template {
  id          String       @id @default(uuid())
  name        String       // e.g., "Modern Startup"
  description String?      
  type        TemplateType @default(SHOWCASE)
  deployment  Json         // Stores framework and repo URL (e.g. { framework: 'NEXTJS', repositoryUrl: '...', envRequirements: [] })
  cmsSchema   Json         // Strict JSON shape for user configuration (e.g. { sections: [...] })
  baseHtmlUrl String?      // Optional fallback
  createdAt   DateTime     @default(now())
  
  websites    Website[]
}

// 5. The Deployed Website
model Website {
  id          String   @id @default(uuid())
  businessId  String
  domain      String?  @unique // Custom domains mapping
  vercelUrl   String?  
  cmsData     Json?    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  templateId  String
  template    Template @relation(fields: [templateId], references: [id])
}

// 6. Social Media Content
model SocialMediaPost {
  id           String   @id @default(uuid())
  businessId   String
  platform     String   // e.g., "INSTAGRAM", "TWITTER"
  content      String   
  hashtags     String[]
  status       String   @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// 7. Generic Agent Execution Workflow (Crucial for generic queues!)
model AgentTask {
  id           String     @id @default(uuid())
  businessId   String
  taskType     TaskType
  status       TaskStatus @default(QUEUED)
  inputData    Json       // The JSON payload matching the React form
  outputData   Json?      // Output generated by Genkit
  logs         String?    
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
