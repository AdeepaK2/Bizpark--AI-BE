FROM node:20-alpine AS builder

WORKDIR /app

RUN apk add --no-cache python3 make g++

COPY Bizpark.Core/package*.json ./Bizpark.Core/
COPY Bizpark.Admin/package*.json ./Bizpark.Admin/

WORKDIR /app/Bizpark.Core
RUN npm ci
COPY Bizpark.Core ./
RUN npm run build

WORKDIR /app/Bizpark.Admin
RUN npm ci
COPY Bizpark.Admin ./
RUN npm run build
RUN npm prune --omit=dev

WORKDIR /app/Bizpark.Core
RUN npm prune --omit=dev

FROM node:20-alpine AS runtime

ENV NODE_ENV=production
ENV PORT=3002

WORKDIR /app

COPY --from=builder /app/Bizpark.Core/package*.json ./Bizpark.Core/
COPY --from=builder /app/Bizpark.Core/dist ./Bizpark.Core/dist
COPY --from=builder /app/Bizpark.Core/node_modules ./Bizpark.Core/node_modules
COPY --from=builder /app/Bizpark.Admin/package*.json ./Bizpark.Admin/
COPY --from=builder /app/Bizpark.Admin/dist ./Bizpark.Admin/dist
COPY --from=builder /app/Bizpark.Admin/node_modules ./Bizpark.Admin/node_modules

WORKDIR /app/Bizpark.Admin

EXPOSE 3002
CMD ["npm", "run", "start:prod"]
