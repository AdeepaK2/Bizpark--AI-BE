FROM node:18-alpine
WORKDIR /app

# Copy the entire monorepo to preserve relative paths
COPY . .

# Build Core first
WORKDIR /app/Bizpark.Core
RUN npm install
RUN npm run build

# Build Commerce
WORKDIR /app/Bizpark.Commerce
RUN npm install
RUN npm run build

EXPOSE 3003
CMD ["npm", "run", "start:prod"]
