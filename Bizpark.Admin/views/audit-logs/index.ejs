<%- include('../partials/header') %>
<table class="table">
  <thead><tr><th>Time</th><th>Action</th><th>Target</th><th>Admin</th></tr></thead>
  <tbody>
    <% logs.forEach((log) => { %>
      <tr>
        <td><%= log.createdAt ? log.createdAt.toISOString().slice(0, 16).replace('T', ' ') : '-' %></td>
        <td><%= log.action %></td>
        <td><%= log.targetType %> <%= log.targetId || '' %></td>
        <td><%= log.adminId || '-' %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../partials/footer') %>
